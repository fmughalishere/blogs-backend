{
  "name": "blog-express-backend",
  "version": "1.0.0",
  "description": "Blog platform backend - Node.js + Express + TypeScript + MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "ts-node": {
    "files": true
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "1.4.6",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-async-handler": "1.2.0",
    "jsonwebtoken": "9.0.2",
    "mongoose": "8.5.1",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.7",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "20.14.13",
    "nodemon": "3.1.4",
    "ts-node": "10.9.2",
    "typescript": "5.5.4"
